# Copy this file to .env and fill in your API keys
# Get Anthropic API key: https://console.anthropic.com
# Get Tavily API key: https://app.tavily.com (free tier: 1000 req/month)

ANTHROPIC_API_KEY=your-anthropic-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here

# App login. Set this to require a password before the API can be used.
# Leave blank for unauthenticated local development (NOT safe for deployment).
APP_PASSWORD=
SESSION_TTL_HOURS=12

# Optional: Fernet key for encrypting stored secrets at rest. Auto-generated
# next to the DB if unset. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=

# Optional overrides (defaults shown)
DATABASE_URL=sqlite:///./data/research.db
CHROMA_PERSIST_DIR=./data/chroma
UPLOADS_DIR=./data/uploads
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
MAX_SEARCH_RESULTS=10
CORS_ORIGINS=http://localhost:3000

# Daily Digest Email (optional)
# Gmail app password: Google Account → Security → 2-Step Verification → App passwords
DIGEST_EMAIL_TO=
DIGEST_EMAIL_FROM=
DIGEST_SMTP_PASSWORD=
DIGEST_TOPICS=AI policy,AI regulation,AI governance,AI safety
